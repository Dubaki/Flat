---
import '../index.css';
import Navbar from '../components/layout/Navbar';
import Footer from '../components/layout/Footer';
import CookieConsent from '../components/ui/CookieConsent';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Профессиональный ремонт квартир в Екатеринбурге без посредников." } = Astro.props;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="google-site-verification" content="roE3luxifAjuSWS7_Oj2uY6kZ6wivAYQyc4OcObYbU4" />
		
		<!-- Open Graph / Social -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		
		<!-- Yandex.Metrica counter -->
		<script type="text/javascript" is:inline>
		   (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
		   m[i].l=1*new Date();
		   for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
		   k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
		   (window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");

		   ym(108280248, "init", { // Замените 108280248 на ваш ID
				clickmap:true,
				trackLinks:true,
				accurateTrackBounce:true,
				webvisor:true
		   });
		</script>
		<noscript><div><img src="https://mc.yandex.ru/watch/108280248" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
		<!-- /Yandex.Metrica counter -->
		
		<!-- Schema.org Markup -->
		<script type="application/ld+json" is:inline>
		{
			"@context": "https://schema.org",
			"@type": "HomeAndConstructionBusiness",
			"name": "Дядя Фёдор",
			"description": "Ремонт квартир в Екатеринбурге без посредников.",
			"telephone": "8-922-18-00-911",
			"email": "3536246@gmail.com",
			"address": {
				"@type": "PostalAddress",
				"addressLocality": "Екатеринбург",
				"addressRegion": "Свердловская область",
				"addressCountry": "RU"
			},
			"priceRange": "от 7500 RUB",
			"areaServed": "Екатеринбург"
		}
		</script>
	</head>
	<body>
		<div class="min-h-screen font-sans w-full overflow-x-hidden break-words">
			<Navbar client:load />
			<main class="w-full">
				<slot />
			</main>
			<Footer client:visible />
			<CookieConsent client:idle />
		</div>
	</body>
</html>

<style is:global>
	:root {
		--accent: 37, 99, 235;
		--accent-light: 219, 234, 254;
		--accent-dark: 30, 58, 138;
	}
	html {
		scroll-behavior: smooth;
	}
</style>
