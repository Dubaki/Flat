---
import Layout from '../layouts/Layout.astro';
import QuizCalc from '../components/calculators/QuizCalc';
---

<Layout
  title="Квиз-калькулятор ремонта в Екатеринбурге | Цена за 4 шага | Дядя Фёдор"
  description="Рассчитайте стоимость ремонта квартиры, санузла или вторичного жилья за 4 шага. Цена показывается сразу — без ввода телефона."
>
  <div class="min-h-screen pt-28 pb-20 relative"
    style="background-image: url('/quiz/photo/arhplan.png'); background-size: cover; background-position: center; background-attachment: fixed;">
    <div class="absolute inset-0 bg-slate-900/70 backdrop-blur-[2px]"></div>
    <div class="relative z-10">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-center mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">
          Калькулятор ремонта
        </h1>
        <p class="text-white/60">
          Екатеринбург и Свердловская область • Цены 2026
        </p>
      </div>
      <QuizCalc client:load />
    </div>
    </div>
  </div>
</Layout>
